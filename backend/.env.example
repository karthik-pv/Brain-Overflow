# ── Required ──────────────────────────────────────────────────────────
# These are needed for the database and API to work.

SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_URL=https://your_project_ref.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
ENCRYPTION_KEY=your_32_char_encryption_key  # any 32+ char string, used by pgcrypto

# ── Optional but recommended ──────────────────────────────────────────
# Speeds up CLI setup. Without it, run `npx supabase login` manually first.
SUPABASE_ACCESS_TOKEN=your_supabase_personal_access_token  # supabase.com/dashboard/account/tokens

# ── Optional (Telegram bot) ──────────────────────────────────────────
# Skip these if you only use the web dashboard. Add them later anytime.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALLOWED_USERS=["123456789"]  # numeric IDs from @userinfobot